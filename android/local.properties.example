# This is an example file. Copy to local.properties and fill in your values.
# NEVER commit local.properties to version control!

# Android SDK path
sdk.dir=C:\\Users\\USER\\AppData\\Local\\Android\\Sdk

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Release Signing Configuration
# Required for building release APKs
KEYSTORE_FILE=koupa-release.jks
KEYSTORE_PASSWORD=your-secure-password
KEY_ALIAS=koupa
KEY_PASSWORD=your-secure-password
